{
  "name": "weltoly",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Weltoly - kişisel finans uygulaması (Tauri + Vue + Vuetify)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue,js}": "eslint --fix"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.9.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vueuse/core": "^12.0.0",
    "date-fns": "^4.1.0",
    "echarts": "^5.6.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.40",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.5.0",
    "vuetify": "^4.1.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "happy-dom": "^15.11.0",
    "lint-staged": "^17.0.8",
    "sass-embedded": "^1.83.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0",
    "vite": "^8.1.5",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.1.10"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "vue-demi@0.14.10": true,
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true,
    "vue-demi@0.13.11": true
  }
}
