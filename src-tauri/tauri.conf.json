{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Weltoly",
  "version": "0.1.0",
  "identifier": "com.stackvo.weltoly",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Weltoly",
        "width": 420,
        "height": 820,
        "minWidth": 360,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://open.er-api.com https://api.coingecko.com; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/fahrettinaksoy/weltoly/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4QTUyQzNFQUFGNkQzMkEKUldRcTAvYXFQaXlsT09IZEdTWExIbEhlQ3FTNUN4b2phNjNXemQ3NWM5K1QzS2FEdERtNTFyMmsK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Finance",
    "publisher": "stackvo",
    "copyright": "© 2026 stackvo",
    "shortDescription": "Kişisel finans yöneticisi",
    "longDescription": "Weltoly - offline çalışan kişisel finans uygulaması. Cüzdanlar, işlemler, kategoriler ve çoklu para birimiyle harcamalarını takip et.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
